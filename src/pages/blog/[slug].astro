---
import BaseLayout from "../../layouts/BaseLayout.astro"
import { getCollection, render } from "astro:content"

export async function getStaticPaths() {
  const posts = await getCollection("blog")
  return posts.map(post => ({
    params: { slug: post.data.slug },
    props: { post },
  }))
}

const { post } = Astro.props
const { Content } = await render(post)
---

<BaseLayout title={post.data.name}>
  <div
    class="mx-auto mb-5 max-w-4xl list-disc space-y-6 text-gray-900 visited:decoration-red-500 dark:text-white"
  >
    <h1 class="mt-10 text-4xl font-bold">{post.data.name}</h1>
    <p class="mt-3">
      {
        new Date(post.data.datePublished).toLocaleDateString("en-US", {
          year: "numeric",
          month: "long",
          day: "numeric",
        })
      }
    </p>
    <article
      class="prose lg:prose-lg prose-headings:text-gray-900 prose-a:text-red-500 prose-a:decoration-red-500 prose-code:text-gray-900 dark:prose-headings:text-white dark:prose-code:text-white text-gray-900 dark:text-white"
    >
      <Content />
    </article>
    <div class="mb-20 underline decoration-red-500 underline-offset-4">
      <a href="/blog">&larr; Back to blog</a>
    </div>
  </div>
</BaseLayout>

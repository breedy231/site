---
import BaseLayout from "../layouts/BaseLayout.astro"
---

<BaseLayout title="Responsive Test - Brendan Reed">
  <div class="p-6 text-gray-900 dark:text-white">
    <h1 class="mb-6 text-4xl font-bold">Responsive Design Test</h1>

    <div class="space-y-8">
      <section class="rounded border border-gray-300 p-4 dark:border-gray-600">
        <h2 class="mb-3 text-2xl font-bold text-red-600">Viewport Meta Tag</h2>
        <p class="mb-2">
          This page includes: <code
            class="rounded bg-gray-200 px-2 py-1 dark:bg-gray-700"
            >width=device-width, initial-scale=1.0</code
          >
        </p>
        <p class="text-sm">
          Without this, iPhone renders at ~980px desktop width
        </p>
      </section>

      <section class="rounded border border-gray-300 p-4 dark:border-gray-600">
        <h2 class="mb-3 text-2xl font-bold text-red-600">
          Tailwind Breakpoint Tests
        </h2>

        <div class="space-y-3">
          <div
            class="rounded bg-blue-500 p-3 text-white md:bg-green-500 lg:bg-purple-500"
          >
            <strong>Color Test:</strong>
            <ul class="mt-1 ml-4 list-disc text-sm">
              <li>Mobile (&lt;768px): <strong>Blue</strong></li>
              <li>Tablet (768px-1023px): <strong>Green</strong></li>
              <li>Desktop (≥1024px): <strong>Purple</strong></li>
            </ul>
          </div>

          <div class="text-base md:text-2xl lg:text-4xl">
            <strong>Font Size Test:</strong> This text should be
            <span class="text-red-600">16px</span> on mobile,
            <span class="text-red-600">24px</span> on tablet, and
            <span class="text-red-600">36px</span> on desktop.
          </div>

          <div class="flex flex-col md:flex-row md:gap-4">
            <div class="rounded bg-red-100 p-2 dark:bg-red-900">Box 1</div>
            <div class="rounded bg-green-100 p-2 dark:bg-green-900">Box 2</div>
            <div class="rounded bg-blue-100 p-2 dark:bg-blue-900">Box 3</div>
          </div>
          <p class="text-sm">
            Boxes should <strong>stack vertically</strong> on mobile, <strong
              >horizontal row</strong
            > on tablet/desktop
          </p>
        </div>
      </section>

      <section class="rounded border border-gray-300 p-4 dark:border-gray-600">
        <h2 class="mb-3 text-2xl font-bold text-red-600">Dark Mode Test</h2>
        <div class="space-y-2">
          <div
            class="rounded bg-white p-3 text-gray-900 dark:bg-gray-800 dark:text-white"
          >
            This box should have white background in light mode, dark background
            in dark mode
          </div>
          <p class="text-sm">
            Check the theme toggle in header. No flash should occur when loading
            pages.
          </p>
        </div>
      </section>

      <section class="rounded border border-gray-300 p-4 dark:border-gray-600">
        <h2 class="mb-3 text-2xl font-bold text-red-600">
          Horizontal Scroll Test
        </h2>
        <div class="overflow-x-auto">
          <div class="min-w-max">
            <p class="whitespace-nowrap">
              This text is very long and should scroll horizontally within its
              container: Lorem ipsum dolor sit amet, consectetur adipiscing
              elit, sed do eiusmod tempor incididunt ut labore et dolore magna
              aliqua.
            </p>
          </div>
        </div>
        <p class="mt-2 text-sm">
          Scrolling should be contained to the box, NOT the full page
        </p>
      </section>

      <section class="rounded border border-gray-300 p-4 dark:border-gray-600">
        <h2 class="mb-3 text-2xl font-bold text-red-600">Image Scaling Test</h2>
        <div class="max-w-full">
          <div
            class="aspect-video w-full rounded bg-gradient-to-r from-blue-500 to-purple-500"
          >
          </div>
        </div>
        <p class="mt-2 text-sm">
          This gradient box should scale to screen width, maintaining 16:9
          aspect ratio
        </p>
      </section>
    </div>

    <div class="mt-8">
      <a
        href="/"
        class="text-blue-600 underline hover:text-blue-800 dark:text-blue-400"
      >
        &larr; Back to home
      </a>
    </div>
  </div>
</BaseLayout>

{
  "name": "brendan-reed-personal-site",
  "private": true,
  "description": "A personal website for Brendan Reed.",
  "version": "2.0.0",
  "license": "0BSD",
  "type": "module",
  "scripts": {
    "build": "astro build",
    "dev": "astro dev",
    "start": "astro dev",
